generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  passwordHash  String
  name          String?
  phone         String?
  createdAt     DateTime    @default(now())
  isAdmin       Boolean     @default(false)
  sellerType    SellerType?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  aircrafts     Aircraft[]
  favorites     Favorite[]
  purchases     Purchase[]
  sessions      Session[]
  spareParts    SparePart[]
}

model Aircraft {
  id                 String             @id @default(cuid())
  sellerId           String
  model              String?
  year               Int?
  price              Decimal?           @db.Decimal(12, 2)
  category           AircraftCategory?
  totalTimeHours     Int?
  engineHours        Int?
  status             AircraftStatus     @default(PENDING_PAYMENT)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  brand              AircraftBrand?
  customBrand        String?
  extraDescription   String?
  listingExpiresAt   DateTime?
  listingStartsAt    DateTime?
  modifications      String?
  priceOnRequest     Boolean            @default(false)
  purchaseId         String?
  renewalEmailSentAt DateTime?
  shortDescription   String
  title              String
  city               String
  province           String
  purchase           Purchase?          @relation(fields: [purchaseId], references: [id])
  seller             User               @relation(fields: [sellerId], references: [id])
  documents          AircraftDocument[]
  images             AircraftImage[]
  favorites          Favorite[]
  leads              Lead[]
  reports            Report[]
  tags               Tag[]              @relation("AircraftToTag")

  @@index([brand, model])
  @@index([price])
  @@index([category])
  @@index([status])
  @@index([province, city])
}

model SparePart {
  id                 String             @id @default(cuid())
  sellerId           String
  title              String
  shortDescription   String
  price              Decimal?           @db.Decimal(12, 2)
  priceOnRequest     Boolean            @default(false)
  category           SparePartCategory
  condition          SparePartCondition
  city               String
  province           String
  brand              String?
  model              String?
  partNumber         String?
  extraDescription   String?
  status             SparePartStatus    @default(PENDING_PAYMENT)
  purchaseId         String?
  listingStartsAt    DateTime?
  listingExpiresAt   DateTime?
  renewalEmailSentAt DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  favorites          Favorite[]
  reports            Report[]
  purchase           Purchase?          @relation(fields: [purchaseId], references: [id])
  seller             User               @relation(fields: [sellerId], references: [id])
  images             SparePartImage[]
  leads              SparePartLead[]

  @@index([category])
  @@index([condition])
  @@index([price])
  @@index([status])
  @@index([province, city])
}

model AircraftImage {
  id         String   @id @default(cuid())
  aircraftId String
  url        String
  order      Int      @default(0)
  aircraft   Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
}

model SparePartImage {
  id          String    @id @default(cuid())
  sparePartId String
  url         String
  order       Int       @default(0)
  sparePart   SparePart @relation(fields: [sparePartId], references: [id], onDelete: Cascade)
}

model AircraftDocument {
  id         String   @id @default(cuid())
  aircraftId String
  url        String
  name       String
  uploadedAt DateTime @default(now())
  aircraft   Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
}

model Lead {
  id         String   @id @default(cuid())
  aircraftId String
  buyerName  String
  buyerEmail String
  buyerPhone String?
  message    String
  createdAt  DateTime @default(now())
  aircraft   Aircraft @relation(fields: [aircraftId], references: [id])
}

model SparePartLead {
  id          String    @id @default(cuid())
  sparePartId String
  buyerName   String
  buyerEmail  String
  buyerPhone  String?
  message     String
  createdAt   DateTime  @default(now())
  sparePart   SparePart @relation(fields: [sparePartId], references: [id])
}

model Favorite {
  id          String     @id @default(cuid())
  userId      String
  aircraftId  String?
  sparePartId String?
  aircraft    Aircraft?  @relation(fields: [aircraftId], references: [id])
  sparePart   SparePart? @relation(fields: [sparePartId], references: [id])
  user        User       @relation(fields: [userId], references: [id])

  @@unique([userId, aircraftId, sparePartId])
}

model Report {
  id            String       @id @default(cuid())
  aircraftId    String?
  reason        String
  details       String?
  reporterEmail String?
  status        ReportStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  sparePartId   String?
  aircraft      Aircraft?    @relation(fields: [aircraftId], references: [id])
  sparePart     SparePart?   @relation(fields: [sparePartId], references: [id])
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  aircrafts Aircraft[] @relation("AircraftToTag")
}

model Plan {
  id            String     @id @default(cuid())
  name          String
  sellerType    SellerType
  postsIncluded Int
  price         Decimal    @db.Decimal(10, 2)
  isActive      Boolean    @default(true)
  purchases     Purchase[]
}

model Purchase {
  id               String        @id @default(cuid())
  userId           String
  planId           String
  creditsTotal     Int
  creditsRemaining Int
  mpPreferenceId   String?
  paymentStatus    PaymentStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  aircraftsPosted  Aircraft[]
  plan             Plan          @relation(fields: [planId], references: [id])
  user             User          @relation(fields: [userId], references: [id])
  sparePartsPosted SparePart[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum SellerType {
  PARTICULAR
  MAYORISTA
}

enum AircraftStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  SOLD
}

enum SparePartStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  SOLD
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AircraftCategory {
  BIMOTOR
  MONOMOTOR
  FUMIGADOR_PISTON
  FUMIGADOR_TURBOHELICE
  EXPERIMENTAL
  HELICOPTERO
  PROYECTO
}

enum AircraftBrand {
  AIR_TRACTOR
  CESSNA
  PIPER
  PZL
  GRUMMAN
  EMBRAER
  OTHER
  BELL
  CICARE
  AIRBUS
  AERO_BOERO
  BEECHCRAFT
}

enum SparePartCategory {
  MECANICO
  ESTRUCTURAL
  PIEZA_MOVIL
  AVIONICA_Y_RADIO
  EQUIPO_DE_FUMIGACION
}

enum SparePartCondition {
  NUEVO
  USADO
  REMANUFACTURADO
}
