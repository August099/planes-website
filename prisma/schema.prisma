generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?           
  image         String?             
  passwordHash  String?             

  name          String?             
  phone         String?
  sellerType    SellerType?
  isAdmin       Boolean    @default(false)
  createdAt     DateTime   @default(now())

  accounts      Account[]           
  sessions      Session[]          

  aircrafts     Aircraft[]
  favorites     Favorite[]
  purchases     Purchase[]
}

model Aircraft {
  id                String          @id @default(cuid())
  seller            User            @relation(fields: [sellerId], references: [id])
  sellerId          String

  // Obligatorios
  title             String
  shortDescription  String          @db.Text
  price             Decimal?        @db.Decimal(12, 2)
  priceOnRequest    Boolean         @default(false)

  // Opcionales - se ocultan en la UI si vienen null
  brand             AircraftBrand?
  customBrand       String?         // solo se usa si brand = OTHER
  model             String?
  year              Int?
  category          AircraftCategory?
  totalTimeHours    Int?
  engineHours       Int?
  location          String?
  extraDescription  String?         @db.Text
  modifications     String?         @db.Text

  status            AircraftStatus  @default(PENDING_PAYMENT)

  purchase          Purchase?       @relation(fields: [purchaseId], references: [id])
  purchaseId        String?

  listingStartsAt     DateTime?
  listingExpiresAt    DateTime?
  renewalEmailSentAt  DateTime?     // evita mandar el mail de "venció" más de una vez

  images            AircraftImage[]
  documents         AircraftDocument[]
  leads             Lead[]
  favorites         Favorite[]
  reports           Report[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([brand, model])
  @@index([price])
  @@index([category])
  @@index([status])
}

model AircraftImage {
  id         String   @id @default(cuid())
  aircraftId String
  url        String
  order      Int      @default(0)
  aircraft   Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
}

model AircraftDocument {
  id         String   @id @default(cuid())
  aircraftId String
  url        String
  name       String
  uploadedAt DateTime @default(now())
  aircraft   Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
}

model Lead {
  id         String   @id @default(cuid())
  aircraftId String
  buyerName  String
  buyerEmail String
  buyerPhone String?
  message    String
  createdAt  DateTime @default(now())
  aircraft   Aircraft @relation(fields: [aircraftId], references: [id])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  aircraftId String
  aircraft   Aircraft @relation(fields: [aircraftId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, aircraftId])
}

model Report {
  id            String       @id @default(cuid())
  aircraftId    String
  reason        String
  details       String?
  reporterEmail String?
  status        ReportStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  aircraft      Aircraft     @relation(fields: [aircraftId], references: [id])
}

model Plan {
  id            String     @id @default(cuid())
  name          String
  sellerType    SellerType
  postsIncluded Int
  price         Decimal    @db.Decimal(10, 2)
  isActive      Boolean    @default(true)
  purchases     Purchase[]
}

model Purchase {
  id               String        @id @default(cuid())
  userId           String
  planId           String
  creditsTotal     Int
  creditsRemaining Int
  mpPreferenceId   String?
  paymentStatus    PaymentStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  aircraftsPosted  Aircraft[]
  plan             Plan          @relation(fields: [planId], references: [id])
  user             User          @relation(fields: [userId], references: [id])
}

enum SellerType {
  PARTICULAR
  MAYORISTA
}

enum AircraftBrand {
  AIR_TRACTOR
  CESSNA
  PIPER
  PZL
  GRUMMAN
  EMBRAER
  OTHER
}

enum AircraftCategory {
  MONOMOTOR
  MULTIMOTOR
  TURBOHELICE
  JET
  HELICOPTERO
}

enum AircraftStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  SOLD
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
